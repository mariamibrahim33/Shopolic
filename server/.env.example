# Copy this file to `.env` and adjust if needed:  cp .env.example .env

# MongoDB connection (local by default).
# For MongoDB Atlas, replace with your cluster string, e.g.
# MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/shopolic
MONGO_URI=mongodb://127.0.0.1:27017/shopolic

# Port the API listens on (the Angular app expects 3000)
PORT=3000

# Secret used to sign JWT access tokens — change this to any random string.
JWT_SECRET=shopolic_dev_secret_change_me
